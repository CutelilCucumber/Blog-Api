    "dompurify": "^3.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "jws": "^4.0.1",
    "nodemon": "^3.1.14",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "sanitize-html": "^2.17.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
